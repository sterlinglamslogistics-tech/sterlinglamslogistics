rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Sterling Glams Logistics — Firestore security rules
//
// ⚠️  REVIEW BEFORE DEPLOYING: these rules require server-side writes to use
//     firebase-admin (which bypasses rules). Several routes in lib/firestore.ts
//     currently use the client SDK without auth and will be denied by these
//     rules until that migration is done. Until then, deploy these rules
//     alongside switching:
//       app/(app)/api/woocommerce/route.ts        → adminDb
//       app/(app)/api/ratings/[tracking]/route.ts → adminDb
//       app/(app)/api/driver/**                   → adminDb
//       lib/firestore.ts mutation helpers         → adminDb
//
// Deploy with:   firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // Customer tracking page now uses /api/track/[tracking] (server-side admin
    // SDK) so unauthenticated clients no longer need direct Firestore access.
    // Admin dashboard reads are authenticated via Firebase Auth + admin claim.
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Drivers ───────────────────────────────────────────────────────────────
    // Tracking page now fetches driver data through /api/track/[tracking] which
    // strips password, phone, and email before returning. Admin SDK bypasses
    // these rules so all server-side routes continue to work.
    //
    // ⚠️ REMAINING RISK: Password hashes still live on driver documents.
    // Recommended long-term fix: move credentials to a private
    // `driverCredentials/{driverId}` subcollection with `allow read, write: if false`.
    match /drivers/{driverId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Settings (business info, notification toggles, driver flags) ──────────
    // Public read so the customer-facing pages can pick up business info,
    // logo, etc. Writes admin-only.
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Notification logs ─────────────────────────────────────────────────────
    // Operational data — admin-only in both directions.
    match /notificationLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Audit logs ────────────────────────────────────────────────────────────
    // Tamper-evident: admin can read; nobody (incl. admin) writes from clients.
    // Server writes via admin SDK which bypasses these rules.
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Admins collection (mapping uid → role) ────────────────────────────────
    match /admins/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // ── Driver live locations (public tracking) ───────────────────────────────
    // Only exposes lat/lng/updatedAt — no name, phone, email, or password.
    // Written server-side only (admin SDK bypasses these rules).
    match /driverLocations/{driverId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
