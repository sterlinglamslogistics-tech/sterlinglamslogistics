# ── Firebase (public client-side keys – exposed in browser bundle) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Hub / Warehouse coordinates ──
NEXT_PUBLIC_HUB_LAT=
NEXT_PUBLIC_HUB_LNG=

# ── Google Maps (public client-side key) ──
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Email sender (not a secret) ──
NOTIFY_FROM_EMAIL=

# ── Twilio (SMS + WhatsApp) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_CONTENT_SID=

# Optional per-event Content Template overrides
# TWILIO_WHATSAPP_CONTENT_SID_ORDER_ACCEPTED=HX...
# TWILIO_WHATSAPP_CONTENT_SID_OUT_FOR_DELIVERY=HX...
# TWILIO_WHATSAPP_CONTENT_SID_DELIVERED=HX...

# ── Resend (Email) ──
RESEND_API_KEY=

# ── Public site origin ──
NEXT_PUBLIC_SITE_ORIGIN=https://yourdomain.com

# ── Driver session HMAC key (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
DRIVER_SESSION_SECRET=

# ── WooCommerce webhook secret ──
WOOCOMMERCE_WEBHOOK_SECRET=

# ── Firebase Admin SDK (single-line JSON) ──
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Upstash Redis (rate limiting) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry ──
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
